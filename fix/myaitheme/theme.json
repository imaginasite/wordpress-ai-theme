{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "defaultDuotone": false,
      "palette": [
        {
          "name": "White",
          "slug": "white",
          "color": "#ffffff"
        },
        {
          "name": "Black",
          "slug": "black",
          "color": "#333333"
        },
        {
          "name": "Dark Gray",
          "slug": "dark-gray",
          "color": "#666666"
        },
        {
          "name": "Gray",
          "slug": "gray",
          "color": "#888888"
        },
        {
          "name": "Light Gray",
          "slug": "light-gray",
          "color": "#d3d3d3"
        },
        {
          "name": "Very Light Gray",
          "slug": "very-light-gray",
          "color": "#f4f4f4"
        },
        {
          "name": "Transparent",
          "slug": "transparent",
          "color": "transparent"
        }
      ]
    },
    "layout": {
      "contentSize": "620px",
      "wideSize": "1140px"
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "%",
        "vw"
      ],
      "blockGap": "24px",
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "XS",
          "slug": "xs",
          "size": "0.5rem"
        },
        {
          "name": "SM",
          "slug": "sm",
          "size": "1rem"
        },
        {
          "name": "MD",
          "slug": "md",
          "size": "1.5rem"
        },
        {
          "name": "LG",
          "slug": "lg",
          "size": "2rem"
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "3rem"
        },
        {
          "name": "2XL",
          "slug": "2xl",
          "size": "4rem"
        },
        {
          "name": "3XL",
          "slug": "3xl",
          "size": "6rem"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "name": "System",
          "slug": "system",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
        },
        {
          "name": "Serif",
          "slug": "serif",
          "fontFamily": "Georgia, 'Times New Roman', Times, serif"
        },
        {
          "name": "Monospace",
          "slug": "monospace",
          "fontFamily": "'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem",
          "fluid": {
            "min": "1rem",
            "max": "1.25rem"
          }
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.125rem",
          "fluid": {
            "min": "1.125rem",
            "max": "1.5rem"
          }
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "1.75rem",
          "fluid": {
            "min": "1.75rem",
            "max": "2rem"
          }
        },
        {
          "name": "XXL",
          "slug": "xxl",
          "size": "2.15rem",
          "fluid": {
            "min": "2.15rem",
            "max": "3rem"
          }
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--black)"
    },
    "spacing": {
      "blockGap": "24px",
      "padding": {
        "top": "0",
        "right": "2rem",
        "bottom": "0",
        "left": "2rem"
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.5"
    },
    "elements": {
      "heading": {
        "typography": {
          "lineHeight": "1.125",
          "fontWeight": "700"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xxl)"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xl)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--black)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--dark-gray)"
          }
        },
        "typography": {
          "textDecoration": "underline"
        }
      },
      "button": {
        "color": {
          "background": "#333333",
          "text": "#ffffff"
        },
        "border": {
          "radius": "0.5rem"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1.5rem",
            "bottom": "0.75rem",
            "left": "1.5rem"
          }
        },
        ":hover": {
          "color": {
            "background": "#888888",
            "text": "#ffffff"
          }
        }
      },
      "form": {
        "spacing": {
          "blockGap": "0.5rem"
        }
      },
      "label": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "600"
        },
        "color": {
          "text": "#333333"
        },
        "spacing": {
          "margin": {
            "bottom": "0.5rem"
          }
        }
      },
      "input": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "lineHeight": "1.5"
        },
        "color": {
          "text": "#333333",
          "background": "#ffffff"
        },
        "border": {
          "color": "#d3d3d3",
          "width": "1px",
          "radius": "0.5rem"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1rem",
            "bottom": "0.75rem",
            "left": "1rem"
          }
        },
        ":focus": {
          "outline": {
            "color": "#666666",
            "width": "2px",
            "style": "solid",
            "offset": "2px"
          },
          "border": {
            "color": "#666666"
          }
        }
      },
      "textarea": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "lineHeight": "1.5"
        },
        "color": {
          "text": "#333333",
          "background": "#ffffff"
        },
        "border": {
          "color": "#d3d3d3",
          "width": "1px",
          "radius": "0.5rem"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1rem",
            "bottom": "0.75rem",
            "left": "1rem"
          }
        },
        ":focus": {
          "outline": {
            "color": "#666666",
            "width": "2px",
            "style": "solid",
            "offset": "2px"
          },
          "border": {
            "color": "#666666"
          }
        }
      },
      "select": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "lineHeight": "1.5"
        },
        "color": {
          "text": "#333333",
          "background": "#ffffff"
        },
        "border": {
          "color": "#d3d3d3",
          "width": "1px",
          "radius": "0.5rem"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1rem",
            "bottom": "0.75rem",
            "left": "1rem"
          }
        },
        ":focus": {
          "outline": {
            "color": "#666666",
            "width": "2px",
            "style": "solid",
            "offset": "2px"
          },
          "border": {
            "color": "#666666"
          }
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "600"
        }
      },
      "core/post-title": {
        "typography": {
          "lineHeight": "1.125"
        }
      },
      "core/query-pagination": {
        "spacing": {
          "margin": {
            "top": "2rem"
          }
        }
      },
      "woocommerce/product-button": {
        "border": {
          "radius": "0.5rem"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "front-page",
      "title": "Front Page",
      "postTypes": [
        "page"
      ]
    }
  ]
}