{
    "version": 2,
    "templateParts": [
        {
            "area": "header",
            "name": "header",
            "title": "Header"
        },
        {
            "area": "footer",
            "name": "footer",
            "title": "Footer"
        }
    ],
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "620px",
            "wideSize": "1140px",
            "blockGap": "24px"
        },
        "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "name": "System Font",
          "slug": "system",
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif"
        },
        {
          "name": "Serif",
          "slug": "serif",
          "fontFamily": "\"Times New Roman\", \"New York\", Times, \"Noto Serif\", serif"
        },
        {
          "name": "Monospace",
          "slug": "monospace",
          "fontFamily": "Consolas, Menlo, Monaco, \"SF Mono\", \"DejaVu Sans Mono\", \"Roboto Mono\", \"Courier New\", Courier, monospace"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem",
          "fluid": {
            "min": "1rem",
            "max": "1.125rem"
          }
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.5rem",
          "fluid": {
            "min": "1.25rem",
            "max": "1.5rem"
          }
        },
        {
          "name": "X-Large",
          "slug": "x-large",
          "size": "2.25rem",
          "fluid": {
            "min": "1.75rem",
            "max": "2.25rem"
          }
        },
        {
          "name": "XX-Large",
          "slug": "xx-large",
          "size": "3.5rem",
          "fluid": {
            "min": "2.5rem",
            "max": "3.5rem"
          }
        },
        {
          "name": "Display",
          "slug": "display",
          "size": "5rem",
          "fluid": {
            "min": "3rem",
            "max": "5rem"
          }
        }
      ],
            "lineHeight": true
        },
        "color": {
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "palette": [
                {
                    "color": "#ffffff",
                    "name": "White",
                    "slug": "white"
                },
                {
                    "color": "#000000",
                    "name": "Black",
                    "slug": "black"
                },
                {
                    "color": "#666666",
                    "name": "Dark Gray",
                    "slug": "dark-gray"
                },
                {
                    "color": "#888888",
                    "name": "Gray",
                    "slug": "gray"
                },
                {
                    "color": "#d3d3d3",
                    "name": "Light Gray",
                    "slug": "light-gray"
                },
                {
                    "color": "#f4f4f4",
                    "name": "Very Light Gray",
                    "slug": "very-light-gray"
                },
                {
                    "color": "transparent",
                    "name": "Transparent",
                    "slug": "transparent"
                }
            ]
        },
        "spacing": {
            "blockGap": true,
            "padding": true,
            "margin": true,
            "spacingSizes": [
                {
                    "name": "10 - Tiny",
                    "size": "0.25rem",
                    "slug": "10"
                },
                {
                    "name": "20 - Small",
                    "size": "0.5rem",
                    "slug": "20"
                },
                {
                    "name": "30 - Base",
                    "size": "1rem",
                    "slug": "30"
                },
                {
                    "name": "40 - Medium",
                    "size": "1.5rem",
                    "slug": "40"
                },
                {
                    "name": "50 - Large",
                    "size": "2rem",
                    "slug": "50"
                },
                {
                    "name": "60 - X-Large",
                    "size": "3rem",
                    "slug": "60"
                },
                {
                    "name": "70 - XX-Large",
                    "size": "4rem",
                    "slug": "70"
                },
                {
                    "name": "80 - Section",
                    "size": "6rem",
                    "slug": "80"
                }
            ]
        }
    },
    "styles": {
        "typography": {
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.5"
        },
        "elements": {
            "heading": {
                "typography": {
                    "lineHeight": "1.125"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--black)"
                },
                "typography": {
                    "textDecoration": "underline"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--dark-gray)"
                    }
                }
            },
            "button": {
                "border": {
                    "radius": "0px",
                    "width": "2px"
                },
                "color": {
                    "background": "var(--wp--preset--color--black)",
                    "text": "var(--wp--preset--color--white)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--white)",
                        "background": "var(--wp--preset--color--gray)"
                    }
                }
            }
        },
        "blocks": {
            "core/button": {
                "variations": {
                    "outline": {
                        "border": {
                            "width": "2px",
                            "color": "var(--wp--preset--color--black)"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--black)"
                        },
                        ":hover": {
                            "color": {
                                "background": "var(--wp--preset--color--black)",
                                "text": "var(--wp--preset--color--white)"
                            }
                        }
                    },
                    "ghost": {
                        "border": {
                            "width": "0px"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--black)"
                        },
                        ":hover": {
                            "color": {
                                "background": "var(--wp--preset--color--very-light-gray)",
                                "text": "var(--wp--preset--color--black)"
                            }
                        }
                    },
                    "pill": {
                        "border": {
                            "radius": "9999px",
                            "width": "2px"
                        },
                        "color": {
                            "background": "var(--wp--preset--color--black)",
                            "text": "var(--wp--preset--color--white)"
                        },
                        ":hover": {
                            "color": {
                                "background": "var(--wp--preset--color--gray)",
                                "text": "var(--wp--preset--color--white)"
                            }
                        }
                    }
                }
            },
            "core/list": {
                "variations": {
                    "checkmark": {
                        "color": {
                            "text": "var(--wp--preset--color--black)"
                        }
                    },
                    "arrow": {
                        "color": {
                            "text": "var(--wp--preset--color--black)"
                        }
                    },
                    "plus": {
                        "color": {
                            "text": "var(--wp--preset--color--black)"
                        }
                    },
                    "numbered": {
                        "color": {
                            "text": "var(--wp--preset--color--black)"
                        }
                    },
                    "no-bullets": {
                        "color": {
                            "text": "var(--wp--preset--color--black)"
                        }
                    }
                }
            }
        }
    }
}